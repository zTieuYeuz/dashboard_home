# ──────────────────────────────────────────────────────────────────────────
# Cấu hình auto-login FortiGate cho container.
# Copy file này thành ".env" (cùng thư mục) rồi điền giá trị thật:
#     cp .env.example .env && nano .env
# docker-compose tự đọc .env. Đổi site khác → chỉ sửa 3 dòng dưới, KHÔNG sửa .js.
#
# ⚠️ KHÔNG commit .env lên git (đã thêm vào .gitignore). Mật khẩu plaintext nên
#    dùng tài khoản FortiGate riêng cho việc nhúng (đừng dùng super-admin nếu
#    tránh được). Tài khoản auto-login KHÔNG được bật 2FA/FortiToken.
# ──────────────────────────────────────────────────────────────────────────

# Trang FortiGate cần mở (đổi cho từng cơ sở)
FGT_URL=https://fortigate.home-server.id.vn/

# Tài khoản đăng nhập (mọi ký tự đặc biệt trong mật khẩu đều OK)
FGT_USER=
FGT_PASS=
