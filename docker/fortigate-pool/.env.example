# ──────────────────────────────────────────────────────────────────────────
# Cấu hình POOL. Copy thành ".env":  cp .env.example .env && nano .env
# CHỈ cần 2 bộ creds (admin + view) — dùng chung cho TOÀN BỘ site.
# KHÔNG commit .env (đã .gitignore). Account auto-login KHÔNG được bật 2FA.
# ──────────────────────────────────────────────────────────────────────────

# Mật khẩu KasmVNC (đặt gì cũng được vì đã DisableBasicAuth, nhưng nên đặt)
VNC_PW=doi_mat_khau_manh

# Trang FortiGate mở mặc định khi container khởi động
FGT_URL=https://fortigate.home-server.id.vn/

# Tài khoản ADMIN (toàn quyền) — giống nhau trên mọi site
ADM_USER=
ADM_PASS=

# Tài khoản VIEW (chỉ xem) — giống nhau trên mọi site
VIEW_USER=
VIEW_PASS=

# Chỉ cho navigator điều hướng tới domain này (an toàn)
NAV_ALLOW_SUFFIX=.home-server.id.vn
