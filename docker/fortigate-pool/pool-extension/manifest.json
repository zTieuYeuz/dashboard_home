{
  "manifest_version": 3,
  "name": "FortiGate Pool Agent",
  "version": "1.0",
  "description": "Auto-login FortiGate + poll navigator để đổi site (thay cho CDP, vì Chrome 136+ chặn remote-debugging).",
  "background": { "service_worker": "sw.js" },
  "permissions": ["tabs", "alarms"],
  "host_permissions": ["http://127.0.0.1:8080/*"],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["creds.js", "autologin.js", "poller.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["http://192.168.130.3/*"],
      "js": ["hik-creds.js", "hik-login.js"],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": false
    }
  ]
}
