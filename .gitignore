node_modules/

# ── Local-only folders (KHÔNG lên GitHub) ──
# Sắp xếp 2026-07-01: gom file lộn xộn ở root vào 3 thư mục.
# Cloudflare chỉ build từ: worker.js + public/ + wrangler.toml (đều ở root).
#   _docs/  = NOTES, HANDOVER, TEST_PLAN, GIT_BRANCHING_GUIDE, tài liệu bàn giao
#   _infra/ = docker/, n8n-workflows/, frigate-config-ai.yml — hạ tầng, credentials
#   _tools/ = scripts one-off (generate_test_xlsx.py...)
_docs/
_infra/
_tools/

# Env files / local secrets — never commit
.env
.env.local
.dev.vars
.dev.vars.*
*.secret
import-secrets.ps1
sp_tmp.json
dev_tmp.json
wrangler.staging.toml

# ── Defense-in-depth: chặn theo tên kể cả khi file bị tạo lại ở root ──
